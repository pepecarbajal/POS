<Page x:Class="POS.paginas.productos.ProductosPag"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1200"
      Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#8b5cf6" Padding="30,0">
            <Grid>
                <TextBlock Text="Gestión de Productos" 
                          FontSize="28" 
                          FontWeight="Bold" 
                          Foreground="White"
                          VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Removed purple border from form container -->
            <Border Grid.Column="0" 
                   BorderBrush="Transparent" 
                   BorderThickness="0" 
                   Padding="20">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Nuevo Producto" 
                                  FontSize="22" 
                                  FontWeight="Bold" 
                                  Foreground="#8b5cf6"
                                  Margin="0,0,0,20"/>

                        <TextBlock Text="Imagen del Producto" 
                                  FontSize="14" 
                                  FontWeight="SemiBold"
                                  Margin="0,0,0,8"/>
                        <Border BorderBrush="#e0e0e0" 
                               BorderThickness="2" 
                               Height="148"
                               Margin="0,0,0,15"
                               Background="#f5f5f5">
                            <Grid Height="137" VerticalAlignment="Top">
                                <Image x:Name="ProductImagePreview" 
                                      Stretch="Uniform"
                                      Margin="10,10,10,7"/>
                                <StackPanel VerticalAlignment="Center" 
                                           HorizontalAlignment="Center"
                                           x:Name="ImagePlaceholder">
                                    <TextBlock Text="📷" 
                                             FontSize="48" 
                                             HorizontalAlignment="Center"
                                             Foreground="#999"/>
                                    <TextBlock Text="Seleccionar imagen" 
                                             FontSize="14" 
                                             HorizontalAlignment="Center"
                                             Foreground="#666"
                                             Margin="0,10,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <!-- Removed CornerRadius from Button -->
                        <Button Content="Seleccionar Imagen" 
                               Background="#8b5cf6" 
                               Foreground="White"
                               FontWeight="SemiBold"
                               Padding="15,8"
                               Margin="0,0,0,20"
                               BorderThickness="0"
                               Cursor="Hand"
                               Click="SelectImage_Click"/>

                        <TextBlock Text="Nombre del Producto *" 
                                  FontSize="14" 
                                  FontWeight="SemiBold"
                                  Margin="0,0,0,8"/>
                        <TextBox x:Name="NombreTextBox"
                                BorderBrush="#e0e0e0" 
                                BorderThickness="1" 
                                Padding="10"
                                FontSize="14"
                                Margin="0,0,0,15"
                                Height="40"/>

                        <TextBlock Text="Categoría *" 
                                  FontSize="14" 
                                  FontWeight="SemiBold"
                                  Margin="0,0,0,8"/>
                        <ComboBox x:Name="CategoriaComboBox"
                                 BorderBrush="#e0e0e0" 
                                 BorderThickness="1" 
                                 Padding="10"
                                 FontSize="14"
                                 Margin="0,0,0,15"
                                 Height="40">
                            <ComboBoxItem Content="Alimentos"/>
                            <ComboBoxItem Content="Bebidas"/>
                            <ComboBoxItem Content="Accesorios"/>
                            <ComboBoxItem Content="Postres"/>
                            <ComboBoxItem Content="Snacks"/>
                        </ComboBox>

                        <TextBlock Text="Precio *" 
                                  FontSize="14" 
                                  FontWeight="SemiBold"
                                  Margin="0,0,0,8"/>
                        <TextBox x:Name="PrecioTextBox"
                                BorderBrush="#e0e0e0" 
                                BorderThickness="1" 
                                Padding="10"
                                FontSize="14"
                                Margin="0,0,0,15"
                                Height="40"/>

                        <TextBlock Text="Stock Inicial *" 
                                  FontSize="14" 
                                  FontWeight="SemiBold"
                                  Margin="0,0,0,8"/>
                        <TextBox x:Name="StockTextBox"
                                BorderBrush="#e0e0e0" 
                                BorderThickness="1" 
                                Padding="10"
                                FontSize="14"
                                Margin="0,0,0,15"
                                Height="40"/>

                        <CheckBox x:Name="EstadoCheckBox"
                                 Content="Producto Activo"
                                 FontSize="14"
                                 IsChecked="True"
                                 Margin="0,0,0,20"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Removed CornerRadius from Buttons -->
                            <Button Grid.Column="0"
                                   Content="Guardar" 
                                   Background="#8b5cf6" 
                                   Foreground="White"
                                   FontWeight="Bold"
                                   Padding="15,10"
                                   BorderThickness="0"
                                   Cursor="Hand"
                                   Click="GuardarProducto_Click" Grid.ColumnSpan="3"/>


                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="150"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" 
                           BorderBrush="#e0e0e0" 
                           BorderThickness="1" 
                           Background="White"
                           Padding="15,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" 
                                      Text="🔍" 
                                      FontSize="18" 
                                      VerticalAlignment="Center"
                                      Margin="0,0,10,0"
                                      Foreground="#999"/>
                            <TextBox Grid.Column="1" 
                                    x:Name="SearchTextBox"
                                    BorderThickness="0" 
                                    FontSize="14"
                                    VerticalAlignment="Center"
                                    Foreground="#666"
                                    Height="40"
                                    Text="Buscar productos..."
                                    GotFocus="SearchTextBox_GotFocus"
                                    LostFocus="SearchTextBox_LostFocus"
                                    TextChanged="SearchTextBox_TextChanged"/>
                        </Grid>
                    </Border>

                    <ComboBox Grid.Column="2" 
                             x:Name="CategoriaFilterComboBox"
                             Height="40"
                             FontSize="14"
                             BorderBrush="#e0e0e0"
                             Background="White"
                             VerticalContentAlignment="Center"
                             SelectionChanged="CategoriaFilterComboBox_SelectionChanged">
                        <ComboBoxItem Content="Todas las categorías" IsSelected="True"/>
                        <ComboBoxItem Content="Alimentos"/>
                        <ComboBoxItem Content="Bebidas"/>
                        <ComboBoxItem Content="Accesorios"/>
                    </ComboBox>

                    <ComboBox Grid.Column="4" 
                             x:Name="EstadoFilterComboBox"
                             Height="40"
                             FontSize="14"
                             BorderBrush="#e0e0e0"
                             Background="White"
                             VerticalContentAlignment="Center"
                             SelectionChanged="EstadoFilterComboBox_SelectionChanged">
                        <ComboBoxItem Content="Todos" IsSelected="True"/>
                        <ComboBoxItem Content="Activos"/>
                        <ComboBoxItem Content="Inactivos"/>
                    </ComboBox>
                </Grid>

                <Border Grid.Row="1" 
                       BorderBrush="#e0e0e0" 
                       BorderThickness="1"
                       Background="White">
                    <!-- Making DataGrid read-only -->
                    <DataGrid x:Name="ProductsDataGrid"
                             AutoGenerateColumns="False"
                             CanUserAddRows="False"
                             CanUserDeleteRows="False"
                             CanUserResizeRows="False"
                             IsReadOnly="True"
                             HeadersVisibility="Column"
                             GridLinesVisibility="None"
                             BorderThickness="0"
                             Background="White"
                             RowBackground="White"
                             AlternatingRowBackground="White"
                             SelectionMode="Single"
                             SelectionUnit="FullRow"
                             RowHeight="50">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="#333"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="Padding" Value="15,10"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#e0e0e0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="15,0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#333"/>
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Background="{TemplateBinding Background}" 
                                                   BorderThickness="0"
                                                   Padding="15,0">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.CellStyle>

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#f0f0f0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#f9f9f9"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Width="60" Binding="{Binding Id}"/>
                            <DataGridTextColumn Header="Nombre" Width="*" Binding="{Binding Nombre}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Categoría" Width="150" Binding="{Binding Categoria}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#7c3aed"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Precio" Width="120" Binding="{Binding Precio}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Stock" Width="100" Binding="{Binding Stock}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="Estado" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Estado}" 
                                                  HorizontalAlignment="Left">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Estado}" Value="Activo">
                                                            <Setter Property="Foreground" Value="#22c55e"/>
                                                        </DataTrigger>
                                                        <!-- Adding trigger for Stock Bajo status -->
                                                        <DataTrigger Binding="{Binding Estado}" Value="Stock Bajo">
                                                            <Setter Property="Foreground" Value="#f59e0b"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Estado}" Value="Inactivo">
                                                            <Setter Property="Foreground" Value="#ef4444"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Acciones" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <ToggleButton x:Name="ActionsToggleButton"
                                                         Content="⋯" 
                                                         FontSize="20"
                                                         FontWeight="Bold"
                                                         Width="30" 
                                                         Height="30" 
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         Foreground="#666"
                                                         Cursor="Hand"
                                                         HorizontalAlignment="Center"/>

                                            <Popup IsOpen="{Binding IsChecked, ElementName=ActionsToggleButton}"
                                                   StaysOpen="False"
                                                   PlacementTarget="{Binding ElementName=ActionsToggleButton}"
                                                   Placement="Bottom"
                                                   AllowsTransparency="True">
                                                <Border Background="White"
                                                       BorderBrush="#e0e0e0"
                                                       BorderThickness="1"
                                                       Padding="5">
                                                    <StackPanel>
                                                        <Button Content="✏️ Editar"
                                                               Background="Transparent"
                                                               BorderThickness="0"
                                                               Padding="15,8"
                                                               FontSize="14"
                                                               HorizontalContentAlignment="Left"
                                                               Cursor="Hand"
                                                               Click="EditarProducto_Click"
                                                               Tag="{Binding}">
                                                            <Button.Style>
                                                                <Style TargetType="Button">
                                                                    <Setter Property="Background" Value="Transparent"/>
                                                                    <Style.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="Background" Value="#f0f0f0"/>
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                        <Button Content="🗑️ Borrar"
                                                               Background="Transparent"
                                                               BorderThickness="0"
                                                               Padding="15,8"
                                                               FontSize="14"
                                                               HorizontalContentAlignment="Left"
                                                               Cursor="Hand"
                                                               Foreground="#ef4444"
                                                               Click="BorrarProducto_Click"
                                                               Tag="{Binding}">
                                                            <Button.Style>
                                                                <Style TargetType="Button">
                                                                    <Setter Property="Background" Value="Transparent"/>
                                                                    <Style.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="Background" Value="#fee"/>
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                    </StackPanel>
                                                </Border>
                                            </Popup>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <Grid Grid.Row="2" Margin="0,15,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" 
                              x:Name="ProductCountText"
                              Text="Mostrando 5 de 5 productos" 
                              FontSize="14" 
                              Foreground="#666"
                              VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" 
                               Orientation="Horizontal">
                        <TextBlock x:Name="ActiveCountText"
                                  Text="4 Activos" 
                                  FontSize="14" 
                                  FontWeight="SemiBold"
                                  Foreground="#22c55e"
                                  Margin="0,0,20,0"
                                  VerticalAlignment="Center"/>
                        <TextBlock x:Name="InactiveCountText"
                                  Text="1 Inactivo" 
                                  FontSize="14" 
                                  FontWeight="SemiBold"
                                  Foreground="#ef4444"
                                  VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
