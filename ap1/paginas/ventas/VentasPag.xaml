<Page x:Class="WPF_ProductTable.paginas.ventas.VentasPag"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Ventas"
      Background="#1a1a1a">

    <Page.Resources>
        <SolidColorBrush x:Key="PurpleBorder" Color="#A855F7"/>
        <SolidColorBrush x:Key="PurpleAccent" Color="#8B4789"/>
        <SolidColorBrush x:Key="YellowNeon" Color="#FAFF00"/>
        <SolidColorBrush x:Key="LimeGreen" Color="#DFFF00"/>
        <SolidColorBrush x:Key="PinkMagenta" Color="#FF1493"/>
        <SolidColorBrush x:Key="CyanAccent" Color="#00CED1"/>
        <SolidColorBrush x:Key="DarkGray" Color="#2d2d2d"/>
        <SolidColorBrush x:Key="LightGray" Color="#3d3d3d"/>

        <Style x:Key="CategoryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource LightGray}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource CyanAccent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource YellowNeon}"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource LimeGreen}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Agregando estilo para las tarjetas de productos -->
        <Style x:Key="ProductCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource LightGray}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PurpleBorder}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource YellowNeon}"/>
                    <Setter Property="Background" Value="#3d3d3d"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" 
                    Background="{StaticResource DarkGray}"
                    Padding="15"
                    Margin="0,0,10,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.Column="0">
                        <TextBox Width="300"
                                 Height="35"
                                 VerticalContentAlignment="Center"
                                 Padding="10,0"
                                 FontSize="14"
                                 Background="White"
                                 BorderThickness="0">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                        <Button Content="Buscar" 
                                Style="{StaticResource ActionButtonStyle}"
                                Margin="10,0,0,0"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="Atender sig.Cliente"
                            Background="{StaticResource CyanAccent}"
                            Foreground="White"
                            FontSize="14"
                            FontWeight="Bold"
                            Padding="15,8"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="10,0"/>

                    <TextBlock Grid.Column="2"
                               Text="Clave NFC"
                               Foreground="{StaticResource PinkMagenta}"
                               FontSize="14"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Margin="10,0"/>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Background="{StaticResource DarkGray}"
                    Padding="10"
                    Margin="0,5,10,5">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Categoría 1" Style="{StaticResource CategoryButtonStyle}"/>
                    <Button Content="Categoría 2" Style="{StaticResource CategoryButtonStyle}"/>
                    <Button Content="Categoría 3" Style="{StaticResource CategoryButtonStyle}"/>
                    <Button Content="Categoría 4" Style="{StaticResource CategoryButtonStyle}"/>
                    <Button Content="⚙" 
                            Style="{StaticResource CategoryButtonStyle}"
                            Width="45"
                            Padding="10"/>
                </StackPanel>
            </Border>

            <!-- Reemplazando el placeholder con un grid de tarjetas de productos -->
            <Border Grid.Row="2"
                    Background="{StaticResource DarkGray}"
                    Margin="0,5,10,0"
                    CornerRadius="5">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ProductosItemsControl" Margin="10">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ProductCardStyle}" Width="180" Height="240">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="140"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <Border Grid.Row="0" 
                                                Background="#2d2d2d"
                                                CornerRadius="6,6,0,0"
                                                Margin="5,5,5,0">
                                            <Image Source="{Binding ImagenUrl}" 
                                                   Stretch="UniformToFill"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"/>
                                        </Border>

                                        <StackPanel Grid.Row="1" Margin="10">
                                            <TextBlock Text="{Binding Nombre}"
                                                       Foreground="White"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="35"
                                                       TextTrimming="CharacterEllipsis"/>

                                            <TextBlock Text="{Binding Precio, StringFormat='${0:N2}'}"
                                                       Foreground="{StaticResource YellowNeon}"
                                                       FontSize="18"
                                                       FontWeight="Bold"
                                                       Margin="0,5,0,0"/>

                                            <TextBlock Text="{Binding Stock, StringFormat='Stock: {0}'}"
                                                       Foreground="{StaticResource CyanAccent}"
                                                       FontSize="11"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Column="1"
                Background="{StaticResource DarkGray}"
                BorderBrush="{StaticResource PurpleBorder}"
                BorderThickness="2,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{StaticResource PurpleAccent}"
                        Padding="15">
                    <TextBlock Text="Carrito"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{StaticResource YellowNeon}"
                               HorizontalAlignment="Center"/>
                </Border>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              Padding="10">
                    <StackPanel>
                        <TextBlock Text="Carrito vacío"
                                   Foreground="White"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   Margin="0,20,0,0"
                                   Opacity="0.5"/>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Background="{StaticResource DarkGray}"
                        Padding="15"
                        BorderBrush="{StaticResource PurpleBorder}"
                        BorderThickness="0,2,0,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="Subtotal:"
                                       Foreground="White"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Left"/>
                            <TextBlock Text="$0.00"
                                       Foreground="White"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid>
                            <TextBlock Text="Total:"
                                       Foreground="{StaticResource YellowNeon}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Left"/>
                            <TextBlock Text="$0.00"
                                       Foreground="{StaticResource YellowNeon}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Button Grid.Row="3"
                        Content="Agregar Productos"
                        Background="{StaticResource PinkMagenta}"
                        Foreground="White"
                        FontSize="16"
                        FontWeight="Bold"
                        Padding="15"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="10"/>
            </Grid>
        </Border>
    </Grid>
</Page>
