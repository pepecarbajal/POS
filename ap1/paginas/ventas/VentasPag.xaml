<Page x:Class="POS.paginas.ventas.VentasPag"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Ventas"
      Background="White">

    <Page.Resources>
        <SolidColorBrush x:Key="PrimaryPurple" Color="#8b5cf6"/>
        <SolidColorBrush x:Key="HoverPurple" Color="#7c3aed"/>
        <SolidColorBrush x:Key="LightBorder" Color="#e0e0e0"/>
        <SolidColorBrush x:Key="LightGray" Color="#f9f9f9"/>
        <SolidColorBrush x:Key="CardGray" Color="#f5f5f5"/>
        <SolidColorBrush x:Key="TextDark" Color="#333"/>
        <SolidColorBrush x:Key="SuccessGreen" Color="#22c55e"/>

        <Style x:Key="CategoryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryPurple}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource HoverPurple}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CategoryComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="BorderBrush" Value="{StaticResource LightBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="50"/>
        </Style>

        <Style x:Key="ProductCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardGray}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LightBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryPurple}"/>
                    <Setter Property="Background" Value="{StaticResource LightGray}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="30">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="450"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,20,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" 
                        Background="White"
                        BorderBrush="{StaticResource LightBorder}"
                        BorderThickness="1"
                        Padding="15"
                        Margin="0,0,0,15">
                <Border BorderBrush="{StaticResource LightBorder}" 
                           BorderThickness="1" 
                           Background="White"
                           Padding="15,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" 
                                      Text="🔍" 
                                      FontSize="18" 
                                      VerticalAlignment="Center"
                                      Margin="0,0,10,0"
                                      Foreground="#999"/>
                        <Grid Grid.Column="1">
                            <TextBlock Text="Buscar productos..."
                                          FontSize="14"
                                          Foreground="#999"
                                          VerticalAlignment="Center"
                                          IsHitTestVisible="False"
                                          x:Name="PlaceholderText">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBox x:Name="SearchTextBox"
                                         BorderThickness="0" 
                                         FontSize="14"
                                         VerticalAlignment="Center"
                                         VerticalContentAlignment="Center"
                                         Foreground="#333"
                                         Height="40"
                                         Padding="0,8,0,0"
                                         Background="Transparent"
                                         TextChanged="SearchTextBox_TextChanged"/>
                        </Grid>
                    </Grid>
                </Border>
            </Border>

            <Border Grid.Row="1"
                        Background="White"
                        BorderBrush="{StaticResource LightBorder}"
                        BorderThickness="1"
                        Padding="10"
                        Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox Grid.Column="0"
                                  x:Name="CategoriasComboBox"
                                  Style="{StaticResource CategoryComboBoxStyle}"
                                  Margin="0,0,10,0"
                                  SelectionChanged="CategoriasComboBox_SelectionChanged"
                                  DisplayMemberPath="Nombre"
                                  SelectedValuePath="Id"/>

                    <Button Grid.Column="1"
                                Content="Combos"
                                Style="{StaticResource CategoryButtonStyle}"
                                Margin="0"
                                Click="CombosButton_Click"/>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                        Background="White"
                        BorderBrush="{StaticResource LightBorder}"
                        BorderThickness="1"
                        Padding="10">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ProductosItemsControl" Margin="10">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ProductCardStyle}" Width="220" Height="300" MouseLeftButtonDown="ProductCard_Click">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="220"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <Border Grid.Row="0" 
                                                    Background="#f5f5f5"
                                                    CornerRadius="6,6,0,0"
                                                    Margin="5,5,5,0">
                                            <Grid>
                                                <Image x:Name="ProductImage"
                                                           Stretch="UniformToFill"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center">
                                                    <Image.Source>
                                                        <Binding Path="ImagenUrl">
                                                            <Binding.TargetNullValue>
                                                                <x:Null/>
                                                            </Binding.TargetNullValue>
                                                        </Binding>
                                                    </Image.Source>
                                                </Image>
                                                <TextBlock Text="📦"
                                                              FontSize="64"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              Foreground="#999">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ImagenUrl}" Value="">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ImagenUrl}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </Border>

                                        <StackPanel Grid.Row="1" Margin="12,8">
                                            <Grid>
                                                <TextBlock Text="{Binding Nombre}"
                                                               Foreground="{StaticResource TextDark}"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap"
                                                               MaxHeight="32"
                                                               TextTrimming="CharacterEllipsis"
                                                               HorizontalAlignment="Left"/>
                                            </Grid>

                                            <Grid Margin="0,4,0,0">
                                                <TextBlock Text="{Binding Precio, StringFormat='${0:N2}'}"
                                                               Foreground="{StaticResource PrimaryPurple}"
                                                               FontSize="14"
                                                               FontWeight="Bold"
                                                               HorizontalAlignment="Left"/>

                                                <TextBlock Text="{Binding Stock}"
                                                               Foreground="{StaticResource SuccessGreen}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Right">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding EsCombo}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Column="1"
                    Background="White"
                    BorderBrush="{StaticResource LightBorder}"
                    BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                            Background="{StaticResource PrimaryPurple}"
                            Padding="15">
                    <TextBlock Text="Carrito"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                </Border>

                <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="10">
                    <ItemsControl x:Name="CarritoItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White"
                                            BorderBrush="{StaticResource LightBorder}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="15"
                                            Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                       Text="{Binding Nombre}"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextDark}"
                                                       TextWrapping="Wrap"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0"
                                                       FontSize="14"
                                                       Foreground="#666"
                                                       Margin="0,3,0,0">
                                                <Run Text="Precio unitario: "/>
                                                <Run Text="{Binding PrecioUnitario, StringFormat='${0:N2}'}" FontWeight="SemiBold"/>
                                        </TextBlock>

                                        <TextBlock Grid.Row="2" Grid.Column="0"
                                                       FontSize="15"
                                                       Foreground="#666"
                                                       Margin="0,3,0,0">
                                                <Run Text="Cantidad: "/>
                                                <Run Text="{Binding Cantidad}" FontWeight="Bold"/>
                                        </TextBlock>

                                        <TextBlock Grid.Row="0" Grid.Column="1" Grid.RowSpan="3"
                                                       Text="{Binding Total, StringFormat='${0:N2}'}"
                                                       FontSize="18"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource PrimaryPurple}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,10,0"/>

                                        <Button Grid.Row="0" Grid.Column="2" Grid.RowSpan="3"
                                                    Content="✕"
                                                    FontSize="18"
                                                    FontWeight="Bold"
                                                    Width="35"
                                                    Height="35"
                                                    Background="#ef4444"
                                                    Foreground="White"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    VerticalAlignment="Center"
                                                    Click="RemoveFromCart_Click"
                                                    ToolTip="Eliminar producto">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}"
                                                                            CornerRadius="4"
                                                                            BorderThickness="0">
                                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                                        VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#dc2626"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Border Grid.Row="2"
                            Background="White"
                            Padding="15"
                            BorderBrush="{StaticResource LightBorder}"
                            BorderThickness="0,1,0,0">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="Total:"
                                           Foreground="{StaticResource PrimaryPurple}"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Left"/>
                            <TextBlock x:Name="TotalTextBlock"
                                           Text="$0.00"
                                           Foreground="{StaticResource PrimaryPurple}"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="3" Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                                Content="Cancelar"
                                Background="#ef4444"
                                Foreground="White"
                                FontSize="18"
                                FontWeight="Bold"
                                Padding="15"
                                BorderThickness="0"
                                Cursor="Hand"
                                Margin="0,0,5,0"
                                Click="CancelarVenta_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="4"
                                                        BorderThickness="0">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#dc2626"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Grid.Column="1"
                                Content="Finalizar Venta"
                                Background="{StaticResource PrimaryPurple}"
                                Foreground="White"
                                FontSize="18"
                                FontWeight="Bold"
                                Padding="15"
                                BorderThickness="0"
                                Cursor="Hand"
                                Margin="5,0,0,0"
                                Click="FinalizarVenta_Click"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>