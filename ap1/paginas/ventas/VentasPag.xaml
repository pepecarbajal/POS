<Page x:Class="POS.paginas.ventas.VentasPag"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Ventas"
      Background="#f8f9fa">

    <Page.Resources>
        <SolidColorBrush x:Key="PrimaryPurple" Color="#8b5cf6"/>
        <SolidColorBrush x:Key="HoverPurple" Color="#7c3aed"/>
        <SolidColorBrush x:Key="LightBorder" Color="#e5e7eb"/>
        <SolidColorBrush x:Key="LightGray" Color="#f9fafb"/>
        <SolidColorBrush x:Key="CardGray" Color="#ffffff"/>
        <SolidColorBrush x:Key="TextDark" Color="#1f2937"/>
        <SolidColorBrush x:Key="SuccessGreen" Color="#22c55e"/>

        <!-- Estilo para botones de categoría -->
        <Style x:Key="CategoryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryPurple}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="24,14"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource HoverPurple}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Estilo para ComboBox -->
        <Style x:Key="CategoryComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="BorderBrush" Value="{StaticResource LightBorder}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Height" Value="48"/>
        </Style>

        <!-- Estilo para tarjetas de productos -->
        <Style x:Key="ProductCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardGray}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LightBorder}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.06" BlurRadius="12" ShadowDepth="0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryPurple}"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#8b5cf6" Opacity="0.2" BlurRadius="20" ShadowDepth="0"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="30">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="480"/>
        </Grid.ColumnDefinitions>

        <!-- Panel izquierdo: Productos -->
        <Grid Grid.Column="0" Margin="0,0,20,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Barra de búsqueda mejorada -->
            <Border Grid.Row="0" 
                    Background="White"
                    CornerRadius="12"
                    Margin="0,0,0,20">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="15" ShadowDepth="0"/>
                </Border.Effect>
                <Grid Height="52">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" 
                            Background="#f3e8ff"
                            Width="52"
                            CornerRadius="12,0,0,12">
                        <TextBlock Text="🔍" 
                                  FontSize="22" 
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center"/>
                    </Border>

                    <TextBox Grid.Column="1"
                            x:Name="SearchTextBox"
                            BorderThickness="0" 
                            FontSize="15"
                            VerticalAlignment="Stretch"
                            VerticalContentAlignment="Center"
                            Foreground="#1f2937"
                            Padding="15,0"
                            Background="Transparent"
                            CaretBrush="#8b5cf6"
                            TextChanged="SearchTextBox_TextChanged"/>
                </Grid>
            </Border>

            <!-- Selector de categorías -->
            <Border Grid.Row="1"
                    Background="White"
                    CornerRadius="12"
                    Padding="20"
                    Margin="0,0,0,20">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="15" ShadowDepth="0"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox Grid.Column="0"
                              x:Name="CategoriasComboBox"
                              Style="{StaticResource CategoryComboBoxStyle}"
                              Margin="0,0,15,0"
                              SelectionChanged="CategoriasComboBox_SelectionChanged"
                              DisplayMemberPath="Nombre"
                              SelectedValuePath="Id"/>

                    <Button Grid.Column="1"
                            Content="🎁 Combos"
                            Style="{StaticResource CategoryButtonStyle}"
                            MinWidth="160"
                            Click="CombosButton_Click"/>
                </Grid>
            </Border>

            <!-- Grid de productos -->
            <Border Grid.Row="2"
                    Background="White"
                    CornerRadius="16"
                    Padding="15">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="15" ShadowDepth="0"/>
                </Border.Effect>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ProductosItemsControl" Margin="5">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ProductCardStyle}" 
                                        Width="230" 
                                        Height="320" 
                                        MouseLeftButtonDown="ProductCard_Click">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="200"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- Imagen del producto -->
                                        <Border Grid.Row="0" 
                                                Background="#fafafa"
                                                CornerRadius="14,14,0,0"
                                                Margin="0"
                                                ClipToBounds="True">
                                            <Grid>
                                                <Image x:Name="ProductImage"
                                                       Stretch="Uniform"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       Margin="10">
                                                    <Image.Source>
                                                        <Binding Path="ImagenUrl">
                                                            <Binding.TargetNullValue>
                                                                <x:Null/>
                                                            </Binding.TargetNullValue>
                                                        </Binding>
                                                    </Image.Source>
                                                </Image>
                                                <TextBlock Text="📦"
                                                          FontSize="72"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          Foreground="#d1d5db">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ImagenUrl}" Value="">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ImagenUrl}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </Border>

                                        <!-- Información del producto -->
                                        <Grid Grid.Row="1" Margin="16,12">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0"
                                                       Text="{Binding Nombre}"
                                                       Foreground="{StaticResource TextDark}"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="40"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,0,0,8"/>

                                            <Grid Grid.Row="1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Precio, StringFormat='${0:N2}'}"
                                                           Foreground="{StaticResource PrimaryPurple}"
                                                           FontSize="18"
                                                           FontWeight="Bold"
                                                           VerticalAlignment="Center"/>

                                                <Border Grid.Column="1"
                                                        Background="#dcfce7"
                                                        CornerRadius="8"
                                                        Padding="8,4"
                                                        VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding EsCombo}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Stock}"
                                                               Foreground="#16a34a"
                                                               FontSize="12"
                                                               FontWeight="Bold"/>
                                                </Border>
                                            </Grid>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Panel derecho: Carrito -->
        <Border Grid.Column="1"
                Background="White"
                CornerRadius="16">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.1" BlurRadius="20" ShadowDepth="0"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header del carrito -->
                <Border Grid.Row="0"
                        Background="{StaticResource PrimaryPurple}"
                        CornerRadius="16,16,0,0"
                        Padding="25,20">
                    <StackPanel>
                        <TextBlock Text="🛒 Carrito de Compra"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="ItemCountText"
                                   Text="0 productos"
                                   FontSize="13"
                                   Foreground="#e9d5ff"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Lista de items del carrito -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              Padding="15"
                              Background="#fafafa">
                    <ItemsControl x:Name="CarritoItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White"
                                        BorderBrush="{StaticResource LightBorder}"
                                        BorderThickness="2"
                                        CornerRadius="12"
                                        Padding="18"
                                        Margin="0,0,0,12">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="8" ShadowDepth="0"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                   Text="{Binding Nombre}"
                                                   FontSize="16"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource TextDark}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,10,0"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0"
                                                   FontSize="13"
                                                   Foreground="#6b7280"
                                                   Margin="0,6,0,0">
                                            <Run Text="Precio: "/>
                                            <Run Text="{Binding PrecioUnitario, StringFormat='${0:N2}'}" 
                                                 FontWeight="SemiBold"
                                                 Foreground="{StaticResource TextDark}"/>
                                        </TextBlock>

                                        <Border Grid.Row="2" Grid.Column="0"
                                                Background="#f3e8ff"
                                                CornerRadius="8"
                                                Padding="10,6"
                                                Margin="0,8,0,0"
                                                HorizontalAlignment="Left">
                                            <TextBlock FontSize="13"
                                                       Foreground="{StaticResource PrimaryPurple}"
                                                       FontWeight="Bold">
                                                <Run Text="Cantidad: "/>
                                                <Run Text="{Binding Cantidad}" FontSize="15"/>
                                            </TextBlock>
                                        </Border>

                                        <StackPanel Grid.Row="0" Grid.Column="1" Grid.RowSpan="2"
                                                    VerticalAlignment="Center"
                                                    Margin="10,0,0,0">
                                            <TextBlock Text="{Binding Total, StringFormat='${0:N2}'}"
                                                       FontSize="20"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource PrimaryPurple}"
                                                       HorizontalAlignment="Right"/>
                                        </StackPanel>

                                        <Button Grid.Row="2" Grid.Column="1"
                                                Content="🗑️"
                                                FontSize="18"
                                                Width="40"
                                                Height="40"
                                                Background="#fee2e2"
                                                Foreground="#dc2626"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Right"
                                                Click="RemoveFromCart_Click"
                                                ToolTip="Eliminar producto">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            CornerRadius="10">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="#fee2e2"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#fecaca"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Total -->
                <Border Grid.Row="2"
                        Background="White"
                        Padding="25,20"
                        BorderBrush="{StaticResource LightBorder}"
                        BorderThickness="0,2,0,0">
                    <Grid>
                        <TextBlock Text="Total:"
                                   Foreground="{StaticResource TextDark}"
                                   FontSize="22"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="TotalTextBlock"
                                   Text="$0.00"
                                   Foreground="{StaticResource PrimaryPurple}"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <!-- Botones de acción -->
                <Grid Grid.Row="3" 
                      Margin="20,15,20,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="✕ Cancelar"
                            Background="#f3f4f6"
                            Foreground="#4b5563"
                            FontSize="16"
                            FontWeight="Bold"
                            Height="56"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="0,0,8,0"
                            Click="CancelarVenta_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#f3f4f6"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#e5e7eb"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Grid.Column="1"
                            Content="✓ Finalizar Venta"
                            Background="{StaticResource PrimaryPurple}"
                            Foreground="White"
                            FontSize="16"
                            FontWeight="Bold"
                            Height="56"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="8,0,0,0"
                            Click="FinalizarVenta_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="{StaticResource PrimaryPurple}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{StaticResource HoverPurple}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>