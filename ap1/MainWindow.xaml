<Window x:Class="POS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Valala Jump Park - Sistema de Gestión"
        Height="700" 
        Width="1200"
        Background="#f5f5f5"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.Resources>
        <Style x:Key="SidebarMenuButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="20,14"/>
            <Setter Property="Margin" Value="8,2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Left" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3d2563"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4c2f7a"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SubmenuButton" TargetType="Button" BasedOn="{StaticResource SidebarMenuButton}">
            <Setter Property="Padding" Value="45,12"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#b8b8b8"/>
            <Setter Property="Margin" Value="8,1"/>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#8b5cf6"/>
            <Setter Property="Margin" Value="20,20,0,8"/>
        </Style>
    </Window.Resources>

    <Grid Background="#f5f5f5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar moderna con gradiente sutil -->
        <Border Grid.Column="0" 
                Background="#1a0b2e"
                BorderBrush="#2d1b4e"
                BorderThickness="0,0,1,0">
            <Border.Effect>
                <DropShadowEffect Color="Black" 
                                  Direction="0" 
                                  ShadowDepth="0" 
                                  BlurRadius="15" 
                                  Opacity="0.3"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo y título -->
                <StackPanel Grid.Row="0" 
                            Margin="0,30,0,20">
                    <Image Source="pack://application:,,,/logo/icono.png" 
                           Width="120"
                           Height="120"
                           Stretch="Uniform"
                           Margin="0,0,0,15"/>
                    <TextBlock Text="VALALA"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,5"/>
                    <TextBlock Text="Sistema de Gestión"
                               FontSize="11"
                               Foreground="#9f7aea"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Menú de navegación -->
                <ScrollViewer Grid.Row="1" 
                              VerticalScrollBarVisibility="Auto"
                              Margin="0,10,0,0">
                    <StackPanel>
                        <!-- Sección Operaciones -->
                        <TextBlock Text="OPERACIONES"
                                   Style="{StaticResource SectionHeader}"/>

                        <Button Style="{StaticResource SidebarMenuButton}"
                                Click="VentasButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🛒" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Ventas" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>


                        <!-- Sección Administración -->
                        <TextBlock Text="ADMINISTRACIÓN"
                                   Style="{StaticResource SectionHeader}"/>

                        <Button x:Name="ConfiguracionButton"
                                Style="{StaticResource SidebarMenuButton}"
                                Click="ConfiguracionButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚙️" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Administración" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Submenu -->
                        <StackPanel x:Name="SubmenuPanel"
                                    Visibility="Collapsed"
                                    Background="#0d0520"
                                    Margin="0,4,0,4">
                            <Button Style="{StaticResource SubmenuButton}"
                                    Click="ProductosButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📦" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Productos" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SubmenuButton}"
                                    Click="CategoriasButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📑" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Categorías" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SubmenuButton}"
                                    Click="CombosButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🎁" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Combos" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                        <TextBlock Text="REGISTROS"
                                Style="{StaticResource SectionHeader}"/>
                        <Button Style="{StaticResource SidebarMenuButton}"
                                Click="DetallesVentasButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📊" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Detalles de Ventas" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>

                <!-- Footer con reloj -->
                <Border Grid.Row="2"
                        Background="#0d0520"
                        Padding="20"
                        Margin="10,0,10,15"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock x:Name="ClockTextBlock"
                                   Text="00:00"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Área de contenido principal -->
        <Grid Grid.Column="1">
            <Frame x:Name="MainFrame"
                   Source="paginas/ventas/VentasPag.xaml"
                   NavigationUIVisibility="Hidden"
                   Background="Transparent"/>
        </Grid>
    </Grid>
</Window>