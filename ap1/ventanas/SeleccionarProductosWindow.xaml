<Window x:Class="POS.ventanas.SeleccionarProductosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Seleccionar Productos" 
        Height="600" 
        Width="500"
        WindowStartupLocation="CenterOwner"
        Background="#f8f9fa"
        ResizeMode="NoResize">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#8b5cf6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Padding="25" BorderBrush="#e5e7eb" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="Seleccionar Productos" 
                          FontSize="24" 
                          FontWeight="Bold" 
                          Foreground="#1f2937"/>
                <TextBlock Text="Marca los productos y ajusta las cantidades" 
                          Foreground="#6b7280" 
                          FontSize="14" 
                          Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Products List -->
        <Border Grid.Row="1" Background="White" Margin="0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ListBox x:Name="ProductosListBox"
                        BorderThickness="0"
                        Background="Transparent"
                        SelectionMode="Multiple">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#f3f4f6"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Background="{TemplateBinding Background}"
                                               BorderBrush="{TemplateBinding BorderBrush}"
                                               BorderThickness="{TemplateBinding BorderThickness}"
                                               Padding="20,15">
                                            <ContentPresenter/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#f9fafb"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <CheckBox Grid.Column="0" Grid.Row="0"
                                        IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                        VerticalAlignment="Center"
                                        Margin="0,0,12,0"/>

                                <TextBlock Grid.Column="1" Grid.Row="0"
                                         Text="{Binding Nombre}"
                                         FontSize="15"
                                         FontWeight="SemiBold"
                                         Foreground="#374151"
                                         VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="1" Grid.Row="1"
                                          Orientation="Horizontal" 
                                          Margin="0,10,0,0"
                                          Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="Cantidad:" 
                                             FontSize="13" 
                                             Foreground="#6b7280"
                                             VerticalAlignment="Center"
                                             Margin="0,0,10,0"/>
                                    <Button Content="-" 
                                           Width="32" 
                                           Height="32"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Background="#f3f4f6"
                                           BorderThickness="1"
                                           BorderBrush="#d1d5db"
                                           Foreground="#374151"
                                           Cursor="Hand"
                                           Click="DecrementarCantidad_Click"
                                           Tag="{Binding}"/>
                                    <TextBox Text="{Binding Cantidad, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                           Width="60"
                                           Height="32"
                                           TextAlignment="Center"
                                           FontSize="14"
                                           BorderBrush="#d1d5db"
                                           BorderThickness="1"
                                           Margin="8,0"
                                           VerticalContentAlignment="Center"/>
                                    <Button Content="+" 
                                           Width="32" 
                                           Height="32"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Background="#f3f4f6"
                                           BorderThickness="1"
                                           BorderBrush="#d1d5db"
                                           Foreground="#374151"
                                           Cursor="Hand"
                                           Click="IncrementarCantidad_Click"
                                           Tag="{Binding}"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>
        </Border>

        <!-- Footer with buttons -->
        <Border Grid.Row="2" Background="White" Padding="25" BorderBrush="#e5e7eb" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancelar" 
                       Background="#6b7280"
                       Foreground="White"
                       Padding="20,12"
                       BorderThickness="0"
                       Cursor="Hand"
                       FontWeight="SemiBold"
                       FontSize="14"
                       Margin="0,0,10,0"
                       Click="Cancelar_Click"/>
                <Button Content="Confirmar Selección" 
                       Style="{StaticResource PrimaryButton}"
                       Click="Confirmar_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
