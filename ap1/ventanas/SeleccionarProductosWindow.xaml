<Window x:Class="POS.ventanas.SeleccionarProductosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Seleccionar Productos" 
        Height="750" 
        Width="650"
        WindowStartupLocation="CenterOwner"
        Background="#f8f9fa"
        ResizeMode="CanResize"
        MinHeight="500"
        MinWidth="550">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- Estilo para botones primarios -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#8b5cf6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="24,14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#7c3aed"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#6d28d9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Estilo para botones secundarios -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#f3f4f6"/>
            <Setter Property="Foreground" Value="#4b5563"/>
            <Setter Property="Padding" Value="24,14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#e5e7eb"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#d1d5db"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Estilo para botones de cantidad -->
        <Style x:Key="QuantityButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#e5e7eb"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#f9fafb"/>
                    <Setter Property="BorderBrush" Value="#8b5cf6"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#f3f4f6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Estilo para CheckBox moderno -->
        <Style x:Key="ModernCheckBox" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Border x:Name="Border"
                                    Width="24"
                                    Height="24"
                                    Background="White"
                                    BorderBrush="#d1d5db"
                                    BorderThickness="2"
                                    CornerRadius="6">
                                <Path x:Name="CheckMark"
                                      Data="M4,11 L9,16 L20,5"
                                      Stroke="#8b5cf6"
                                      StrokeThickness="3"
                                      Visibility="Collapsed"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Margin="2"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Border" Property="Background" Value="#f3e8ff"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#8b5cf6"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#8b5cf6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo para TextBox de cantidad -->
        <Style x:Key="QuantityTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1f2937"/>
            <Setter Property="BorderBrush" Value="#e5e7eb"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                         Focusable="false"
                                         HorizontalScrollBarVisibility="Hidden"
                                         VerticalScrollBarVisibility="Hidden"
                                         VerticalAlignment="Center"
                                         HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#8b5cf6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="16" Margin="15">
        <Border.Effect>
            <DropShadowEffect Color="#000000" 
                            Opacity="0.1" 
                            BlurRadius="30" 
                            ShadowDepth="0"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header mejorado -->
            <Border Grid.Row="0" 
                    Background="#8b5cf6" 
                    CornerRadius="16,16,0,0"
                    Padding="30,25">
                <StackPanel>
                    <TextBlock Text="🛍️ Seleccionar Productos" 
                              FontSize="26" 
                              FontWeight="Bold" 
                              Foreground="White"/>
                    <TextBlock Text="Marca los productos que deseas incluir y ajusta las cantidades" 
                              Foreground="#e9d5ff" 
                              FontSize="14" 
                              Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- Products List con diseño mejorado -->
            <Border Grid.Row="1" 
                    Background="#fafafa" 
                    Margin="0"
                    Padding="15">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                             PanningMode="VerticalOnly"
                             CanContentScroll="True">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar">
                            <Setter Property="Width" Value="10"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ScrollBar">
                                        <Grid>
                                            <Border Background="#f3f4f6" CornerRadius="5" Margin="2"/>
                                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                                <Track.Thumb>
                                                    <Thumb>
                                                        <Thumb.Template>
                                                            <ControlTemplate>
                                                                <Border Background="#c4b5fd" 
                                                                       CornerRadius="5"
                                                                       Margin="2"/>
                                                            </ControlTemplate>
                                                        </Thumb.Template>
                                                    </Thumb>
                                                </Track.Thumb>
                                            </Track>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ScrollBar">
                                                <Grid>
                                                    <Border Background="#e5e7eb" CornerRadius="5" Margin="2"/>
                                                    <Track x:Name="PART_Track" IsDirectionReversed="True">
                                                        <Track.Thumb>
                                                            <Thumb>
                                                                <Thumb.Template>
                                                                    <ControlTemplate>
                                                                        <Border Background="#8b5cf6" 
                                                                               CornerRadius="5"
                                                                               Margin="2"/>
                                                                    </ControlTemplate>
                                                                </Thumb.Template>
                                                            </Thumb>
                                                        </Track.Thumb>
                                                    </Track>
                                                </Grid>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Resources>
                    <ListBox x:Name="ProductosListBox"
                            BorderThickness="0"
                            Background="Transparent"
                            SelectionMode="Multiple">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,10"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Background="White"
                                                   CornerRadius="12"
                                                   Padding="20,18"
                                                   Margin="0,0,0,8">
                                                <Border.Effect>
                                                    <DropShadowEffect Color="#000000" 
                                                                    Opacity="0.05" 
                                                                    BlurRadius="8" 
                                                                    ShadowDepth="0"/>
                                                </Border.Effect>
                                                <ContentPresenter/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border Background="White"
                                                           CornerRadius="12"
                                                           Padding="20,18"
                                                           BorderBrush="#8b5cf6"
                                                           BorderThickness="2"
                                                           Margin="0,0,0,8">
                                                        <Border.Effect>
                                                            <DropShadowEffect Color="#8b5cf6" 
                                                                            Opacity="0.15" 
                                                                            BlurRadius="12" 
                                                                            ShadowDepth="0"/>
                                                        </Border.Effect>
                                                        <ContentPresenter/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Background="Transparent" 
                                      MouseDown="ProductItem_MouseDown"
                                      Tag="{Binding}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <CheckBox Grid.Column="0" Grid.Row="0"
                                            IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                            Style="{StaticResource ModernCheckBox}"
                                            VerticalAlignment="Center"
                                            Margin="0,0,15,0"/>

                                    <StackPanel Grid.Column="1" Grid.Row="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Nombre}"
                                                 FontSize="16"
                                                 FontWeight="SemiBold"
                                                 Foreground="#1f2937"/>
                                    </StackPanel>

                                    <Border Grid.Column="1" Grid.Row="1"
                                           Background="#f9fafb"
                                           CornerRadius="10"
                                           Padding="15,12"
                                           Margin="0,12,0,0"
                                           Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Cantidad:" 
                                                     FontSize="14" 
                                                     FontWeight="SemiBold"
                                                     Foreground="#6b7280"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,15,0"/>
                                            <Button Content="−" 
                                                   Width="36" 
                                                   Height="36"
                                                   FontSize="20"
                                                   Style="{StaticResource QuantityButton}"
                                                   Click="DecrementarCantidad_Click"
                                                   Tag="{Binding}"/>
                                            <TextBox Text="{Binding Cantidad, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                   Width="70"
                                                   Height="36"
                                                   TextAlignment="Center"
                                                   Style="{StaticResource QuantityTextBox}"
                                                   Margin="10,0"
                                                   VerticalContentAlignment="Center"/>
                                            <Button Content="+" 
                                                   Width="36" 
                                                   Height="36"
                                                   FontSize="20"
                                                   Style="{StaticResource QuantityButton}"
                                                   Click="IncrementarCantidad_Click"
                                                   Tag="{Binding}"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </Border>

            <!-- Footer con botones mejorados -->
            <Border Grid.Row="2" 
                    Background="White" 
                    CornerRadius="0,0,16,16"
                    Padding="30,20"
                    BorderBrush="#e5e7eb" 
                    BorderThickness="0,1,0,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancelar" 
                               Style="{StaticResource SecondaryButton}"
                               Margin="0,0,12,0"
                               Click="Cancelar_Click"/>
                        <Button Content="✓ Confirmar Selección" 
                               Style="{StaticResource PrimaryButton}"
                               Click="Confirmar_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>